# Postgres usato dal backend (Express + pg): tabelle events, assignments, staff, ecc.
#
# Deploy Docker: imposta DATABASE_URL nel file .env accanto a pitch-stack/docker-compose.yml
# (vedi pitch-stack/.env.example). Deve essere una riga letterale, es.:
#   DATABASE_URL=postgresql://postgres:LA_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Senza ${ } attorno all'URL (Compose lo interpreterebbe come interpolazione).
#
# Sviluppo locale (npm run dev): esempio sotto. Supabase: Settings → Database → URI; password URL-encoded se serve.
DATABASE_URL=postgres://user:password@localhost:5432/pitch2

# Supabase (auth freelance + API; distinto da DATABASE_URL che punta al Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Magic link e auth (URL frontend PITCH_2)
PITCH_FREELANCE_BASE_URL=https://app.designazionipitch.com
# Reset password: link nella mail (default = PITCH_FREELANCE_BASE_URL)
FRONTEND_BASE_URL=https://app.designazionipitch.com
# URL pubblico backend (per link magic nella mail)
PITCH2_API_URL=https://api.designazionipitch.com

# CORS: default produzione https://apppitch.it; in locale es. http://localhost:3000
# CORS_ORIGIN=http://localhost:3000

# Sessioni (cookie firmati)
SESSION_SECRET=your-secret-min-32-chars
# Dominio cookie (con punto iniziale) se app e API servono il cookie su più host nello stesso dominio registrato.
# Esempi: SESSION_COOKIE_DOMAIN=.designazionipitch.com oppure .apppitch.it ; lasciare vuoto se stesso host per sito e /api.
SESSION_COOKIE_DOMAIN=

# Brevo (invio email designazioni)
BREVO_API_KEY=xkeysib-your-api-key
# Mittente designazioni: default dazn@designazionipitch.com / DAZN Designazioni PITCH.
# Per cambiare in futuro, decommenta e imposta in .env:
# BREVO_SENDER_EMAIL=dazn@designazionipitch.com
# BREVO_SENDER_NAME=DAZN Designazioni PITCH
